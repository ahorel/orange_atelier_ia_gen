# RAG POC — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS commiter .env dans git

# ── Qdrant Cloud ─────────────────────────────────────────────
# Créer un cluster gratuit sur https://cloud.qdrant.io
QDRANT_URL=https://VOTRE-CLUSTER.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=votre_cle_api_qdrant

# ── LLM : Groq (gratuit, sans GPU) ──────────────────────────
# Créer une clé sur https://console.groq.com
GROQ_API_KEY=votre_cle_api_groq

# ── Mode de déploiement ──────────────────────────────────────
# "local"  → Qdrant local dans qdrant_db/ (pas de clés nécessaires)
# "cloud"  → Qdrant Cloud + Groq (partagé entre devs)
RAG_MODE=cloud
