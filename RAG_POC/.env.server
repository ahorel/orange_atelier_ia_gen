# Fichier .env pour le serveur Hetzner
# Copier sur le serveur à la racine du projet sous le nom .env
# NE PAS commiter ce fichier dans git

# ── LLM : Groq (gratuit, sans GPU) ──────────────────────────
# Créer une clé sur https://console.groq.com
GROQ_API_KEY=gsk_votre_cle_groq

# ── Mode serveur : Qdrant tourne en Docker sur le même serveur ──
# Ne pas modifier ces deux lignes
RAG_MODE=server
QDRANT_URL=http://qdrant:6333
